# =============================================================================
# Loopora (InterviewLoop) — Environment Variables Example
# =============================================================================
# Copy this file to `.env.local` and fill in actual values.
# Never commit `.env.local` — it is listed in .gitignore.
# =============================================================================

# --- MongoDB Atlas -----------------------------------------------------------
MONGODB_URI=

# --- NextAuth.js -------------------------------------------------------------
NEXTAUTH_SECRET=
NEXTAUTH_URL=
AUTH_TRUST_HOST=

# --- Google OAuth ------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Google Gemini AI -------------------------------------------------------
GEMINI_API_KEY=

# --- Analytics (PostHog Integration) ----------------------------------------
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=

# --- App Configuration ------------------------------------------------------
NEXT_PUBLIC_FREE_QUESTION_LIMIT=
REVALIDATION_INTERVAL=
RATE_LIMIT_AUTH_MAX=
RATE_LIMIT_PUBLIC_WRITE_MAX=
NEXT_PUBLIC_ANALYTICS_PROVIDER=
