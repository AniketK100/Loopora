# =============================================================================
# InterviewLoop — Environment Variables
# =============================================================================
# Copy this file to `.env.local` and fill in actual values.
# Never commit `.env.local` — it is listed in .gitignore.
# =============================================================================

# --- MongoDB Atlas -----------------------------------------------------------
# Connection string for your MongoDB Atlas cluster.
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbName>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/interviewloop?retryWrites=true&w=majority

# --- NextAuth.js -------------------------------------------------------------
# A random secret used to encrypt JWT tokens and session cookies.
# Generate one with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here

# The canonical URL of your site (used by NextAuth for callbacks).
# In development: http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# --- Google OAuth (optional, add when credentials are available) -------------
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- Cloudinary (optional, uses placeholders if not set) ---------------------
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret

# --- Analytics (abstract layer, configure provider later) --------------------
# NEXT_PUBLIC_ANALYTICS_PROVIDER=none
# Options: "posthog" | "plausible" | "ga4" | "none"
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
# NEXT_PUBLIC_GA4_MEASUREMENT_ID=

# --- Sentry (error monitoring, Phase 10) ------------------------------------
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=

# --- App Configuration ------------------------------------------------------
# Number of free questions per category before signup prompt
NEXT_PUBLIC_FREE_QUESTION_LIMIT=5

# ISR revalidation interval in seconds (default: 1 hour)
REVALIDATION_INTERVAL=3600

# Rate limiting: max requests per minute per IP on auth endpoints
RATE_LIMIT_AUTH_MAX=10

# Rate limiting: max requests per minute per IP on public write endpoints
RATE_LIMIT_PUBLIC_WRITE_MAX=5
