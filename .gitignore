# =============================================================================
# Loopora (InterviewLoop) — .gitignore
# =============================================================================

# --- Dependencies ------------------------------------------------------------
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# --- Next.js build output ----------------------------------------------------
/.next/
/out/
/build
/dist

# --- Environment variables ---------------------------------------------------
# NEVER commit secrets. Only .env.example is tracked.
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local

# --- TypeScript ---------------------------------------------------------------
*.tsbuildinfo
next-env.d.ts

# --- Testing ------------------------------------------------------------------
/coverage
/scratch/

# --- OS files -----------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~

# --- Editor / IDE files -------------------------------------------------------
.vscode/settings.json
.vscode/launch.json
.idea/
*.sublime-project
*.sublime-workspace

# --- Debug logs ---------------------------------------------------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- Vercel -------------------------------------------------------------------
.vercel

# --- Security -----------------------------------------------------------------
*.pem
*.key
*.cert

# --- Turbopack cache ----------------------------------------------------------
.turbo/

# --- Backups (do NOT commit; Local MongoDB + Atlas dumps are the safety net) ---
migration_dump/
migration_dump_atlas_backup/
atlas_backup_production/

# --- Temp / cache / logs -------------------------------------------------------
tmp/
temp/
.cache/
logs/

# --- Misc ---------------------------------------------------------------------
*.log
